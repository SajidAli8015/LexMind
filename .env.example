# ── LLM Provider ─────────────────────────────
# Options: google, openai, anthropic, azure
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional - leave blank if not using)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (optional - leave blank if not using)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── LLM Settings ─────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Embedding Settings ────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# ── Reranker Settings ─────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=40

# ── Retrieval Settings ────────────────────────
MAX_CHUNKS_DENSE=20
MAX_CHUNKS_BM25=20
TOP_K_FINAL=5
SIMILARITY_THRESHOLD=0.0

# ── Storage Paths ─────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
BM25_INDEX_PATH=./data/bm25_index.pkl
EVALUATION_DB_PATH=./data/evaluation.db

# ── Evaluation Thresholds ─────────────────────
GROUNDEDNESS_THRESHOLD=0.75
CITATION_THRESHOLD=0.85
RELEVANCE_THRESHOLD=0.70
MAX_REGENERATIONS=2

# ── Chunking Settings ─────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
CHUNK_MIN_SIZE=50

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
